#!/bin/bash
# Remote iTerm — Python server (7291) + client dev (7292)

SOURCE="$0"
while [ -L "$SOURCE" ]; do SOURCE="$(readlink "$SOURCE")"; done
DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# Handle global installation: if we're in node_modules/.bin, go up to the package root
if [[ "$DIR" == *"node_modules"* ]]; then
  DIR="$(cd "$DIR/../../remote-iterm" && pwd)"
fi

PIDFILE="$DIR/.iterm-server.pid"
LOGFILE="$DIR/.iterm-server.log"
VENV="$DIR/server/.venv"
REQ="$DIR/server/requirements.txt"
STAMP="$VENV/.requirements.sha"

get_local_ip() {
  ipconfig getifaddr en0 2>/dev/null || echo "localhost"
}

# Locate a usable python3 (>=3.8). Verifies it actually runs so we don't pick
# the /usr/bin/python3 Command Line Tools shim that only pops an install dialog.
find_python() {
  local cand
  for cand in /opt/homebrew/bin/python3 /usr/local/bin/python3 "$(command -v python3 2>/dev/null)"; do
    if [ -n "$cand" ] && [ -x "$cand" ] && \
       "$cand" -c 'import sys; sys.exit(0 if sys.version_info >= (3,8) else 1)' >/dev/null 2>&1; then
      echo "$cand"
      return 0
    fi
  done
  return 1
}

# Create the venv once and (re)install deps only when requirements change.
ensure_venv() {
  local py want
  if [ ! -x "$VENV/bin/python" ]; then
    py="$(find_python)" || {
      echo "  No usable python3 (>=3.8) found. Install one, e.g. 'brew install python3'." >&2
      return 1
    }
    echo "  Setting up Python environment…"
    "$py" -m venv "$VENV" || return 1
    "$VENV/bin/python" -m pip install --quiet --upgrade pip
  fi

  want="$(shasum -a 256 "$REQ" | awk '{print $1}')"
  if [ ! -f "$STAMP" ] || [ "$(cat "$STAMP" 2>/dev/null)" != "$want" ]; then
    echo "  Installing Python dependencies…"
    "$VENV/bin/pip" install --quiet -r "$REQ" || return 1
    echo "$want" > "$STAMP"
  fi
  return 0
}

do_start() {
  local shared_key
  if lsof -nP -tiTCP:7291 -sTCP:LISTEN >/dev/null 2>&1; then
    echo "  Already running"
    return 1
  fi
  if lsof -nP -tiTCP:7292 -sTCP:LISTEN >/dev/null 2>&1; then
    echo "  Client port 7292 is already in use"
    return 1
  fi

  ensure_venv || return 1
  shared_key="$("$VENV/bin/python" "$DIR/server/auth.py")" || return 1

  # exec in the subshell so $! is the real daemon pid (not the subshell wrapper),
  # which keeps the pidfile accurate for `stop`.
  ( cd "$DIR/server" && exec "$VENV/bin/python" -u server.py >> "$LOGFILE" 2>&1 ) &
  SERVER_PID=$!

  ( cd "$DIR/client" && exec npx vite --host --port 7292 --strictPort >> "$LOGFILE" 2>&1 ) &
  CLIENT_PID=$!

  echo "$SERVER_PID $CLIENT_PID" > "$PIDFILE"

  IP=$(get_local_ip)
  URL="http://${IP}:7292/#key=${shared_key}"
  "$VENV/bin/python" - "$URL" <<'PYQR'
import sys

url = sys.argv[1]
print()
try:
    import qrcode
    qr = qrcode.QRCode(border=1)
    qr.add_data(url)
    qr.make(fit=True)
    qr.print_ascii(invert=True)
except Exception:
    pass
print()
print("  Remote iTerm")
print()
print(f"  Local:    http://localhost:7292/#key={url.rsplit('#key=', 1)[1]}")
print(f"  Network:  {url}")
print()
print("  Scan the QR from your phone (same Wi-Fi)")
print()
PYQR
}

do_stop() {
  killed=0

  # Primary: kill whatever actually holds our ports, plus their children. This
  # works even if the pidfile is stale or processes were reparented.
  for port in 7291 7292; do
    for pid in $(lsof -nP -tiTCP:$port -sTCP:LISTEN 2>/dev/null); do
      pkill -P "$pid" 2>/dev/null
      kill "$pid" 2>/dev/null && killed=1
    done
  done

  # Also honor the pidfile (and reap its children) in case a process is mid-start
  # and not yet listening.
  if [ -f "$PIDFILE" ]; then
    read -r PIDS < "$PIDFILE"
    for pid in $PIDS; do
      pkill -P "$pid" 2>/dev/null
      kill "$pid" 2>/dev/null && killed=1
    done
    rm -f "$PIDFILE"
  fi

  # Do not let `restart` race processes that have received SIGTERM but have not
  # released their listening sockets yet.
  for _ in {1..20}; do
    listening=0
    for port in 7291 7292; do
      for pid in $(lsof -nP -tiTCP:$port -sTCP:LISTEN 2>/dev/null); do
        listening=1
        kill "$pid" 2>/dev/null && killed=1
      done
    done
    [ "$listening" = "0" ] && break
    sleep 0.1
  done

  if [ "$killed" = "1" ]; then
    echo "  Stopped"
  else
    echo "  Not running"
  fi
}

case "${1:-start}" in
  start)   do_start ;;
  stop)    do_stop ;;
  restart) do_stop; sleep 1; do_start ;;
  *)       echo "Usage: iterm-server [start|stop|restart]" ;;
esac

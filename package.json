{
  "name": "remote-iterm",
  "version": "1.0.1",
  "description": "Control iTerm2 from your phone with a native, event-driven iTerm2 integration",
  "bin": {
    "remote-iterm": "iterm-server"
  },
  "scripts": {
    "postinstall": "cd client && npm install",
    "start": "./iterm-server start",
    "stop": "./iterm-server stop",
    "restart": "./iterm-server restart"
  },
  "keywords": [
    "iterm",
    "iterm2",
    "terminal",
    "remote",
    "macos",
    "mobile",
    "python",
    "iterm2-api",
    "socket.io",
    "pwa"
  ],
  "author": "Alex Speller",
  "contributors": [
    "Ziya Mammadov (https://github.com/mammadovziya)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexspeller/remote-iterm.git"
  },
  "homepage": "https://github.com/alexspeller/remote-iterm#readme",
  "bugs": {
    "url": "https://github.com/alexspeller/remote-iterm/issues"
  },
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "iterm-server",
    "server/",
    "client/",
    "!server/.venv",
    "!server/__pycache__",
    "!server/**/*.pyc",
    "!client/node_modules",
    "!client/dist",
    "README.md",
    "LICENSE",
    "docs/"
  ]
}
